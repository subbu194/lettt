PORT=5000
DB_URL=mongodb://localhost:27017/artrise
JWT_SECRET=your-user-secret
JWT_ADMIN_SECRET=your-admin-secret
JWT_REFRESH_SECRET=your-user-refresh-secret
JWT_ADMIN_REFRESH_SECRET=your-admin-refresh-secret
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1d
NODE_ENV=development
TRUST_PROXY=false

# CORS & Cookie cross-origin settings (required for production)
ALLOWED_ORIGINS=https://your-frontend-domain.com
# Optional: set cookie domain if frontend and backend share a parent domain
# COOKIE_DOMAIN=.your-domain.com

# Cloudflare R2 Storage (required for image uploads)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_BASE_URL=https://your-bucket.your-account-id.r2.dev

# Razorpay (use test keys in test deployment and live keys in production deployment)
RAZORPAY_KEY_ID=rzp_test_or_live_key_id
RAZORPAY_KEY_SECRET=rzp_test_or_live_key_secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Backward compatible (optional):
# MONGODB_URI=mongodb://localhost:27017/artrise
